#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
secrets_dir="$repo_root/secrets/qbittorrent"

mkdir -p "$secrets_dir"

read -r -s -p "qBittorrent password: " password
printf '\n' >&2
read -r -s -p "Confirm qBittorrent password: " password_confirm
printf '\n' >&2

if [ "$password" != "$password_confirm" ]; then
  echo "Passwords do not match." >&2
  exit 1
fi

printf '%s' "$password" > "$secrets_dir/password"
chmod 0600 "$secrets_dir/password"

qbittorrent_password -i "$secrets_dir/password" -f "$secrets_dir/password_pbkdf2"
chmod 0600 "$secrets_dir/password_pbkdf2"
